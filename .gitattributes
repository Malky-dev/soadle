# Normalize line endings
* text=auto eol=lf

# PHP files
*.php text eol=lf

# Markdown
*.md text eol=lf

# JSON / config
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Frontend
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.ico binary